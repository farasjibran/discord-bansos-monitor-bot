# Discord Bot Token
# Dapatkan dari: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Channel ID untuk posting notifikasi
# Klik kanan channel di Discord > Copy ID (aktifkan Developer Mode di Settings)
DISCORD_CHANNEL_ID=your_channel_id_here

# Cron Schedule (default: setiap 1 jam)
# Format: minute hour day month dayOfWeek
# Contoh: "0 * * * *" = setiap jam di menit ke-0
CRON_SCHEDULE=0 * * * *

# URL Website yang akan dimonitor
WEBSITE_URL=https://appverse.id/bansos-ai
